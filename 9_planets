        Returns flat HP reduction to subtract from final_dmg for gather hazards."""
        w = self.wearing
        reductions = {
            "spider nest":     {"light_armor": 5,  "medium_armor": 8,  "heavy_armor": 8},
            "venomous spider": {"light_armor": 5,  "medium_armor": 10, "heavy_armor": 10},
