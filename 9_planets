# ==================== TERMINAL ====================
class Terminal:
    def __init__(self):
        self.fd = sys.stdin.fileno()
        self.old = termios.tcgetattr(self.fd)

    def setup(self):
        tty.setraw(self.fd)

    def cleanup(self):
        sys.stdout.write("\033[2J\033[1;1H\033[?25h")
        termios.tcsetattr(self.fd, termios.TCSANOW, self.old)
        sys.stdout.flush()

    def get_key(self, timeout=0.1):
        r, _, _ = select.select([self.fd], [], [], timeout)
        if not r: return None
        try: char = os.read(self.fd, 1).decode('utf-8', errors='ignore')
        except: return None
        if not char: return None
        if char == '\x1b':
            r2, _, _ = select.select([self.fd], [], [], 0.05)
            if r2:
                seq = os.read(self.fd, 16).decode('utf-8', errors='ignore')
                if seq.startswith("[A"): return 'UP'
                if seq.startswith("[B"): return 'DOWN'
                if seq.startswith("[C"): return 'RIGHT'
                if seq.startswith("[D"): return 'LEFT'
            return None
        return char

    def get_key_no_flush(self, timeout=0.1):
        r, _, _ = select.select([self.fd], [], [], timeout)
        if not r: return None
        try: char = os.read(self.fd, 1).decode('utf-8', errors='ignore')
        except: return None
        if not char: return None
        if char == '\x1b':
            r2, _, _ = select.select([self.fd], [], [], 0.05)
            if r2:
                seq = os.read(self.fd, 16).decode('utf-8', errors='ignore')
                if seq.startswith("[A"): return 'UP'
                if seq.startswith("[B"): return 'DOWN'
            return 'ESC'
        return char

    def show_menu(self, lines):
        out = "\r\n".join(vfit(str(l), TERM_WIDTH) for l in lines)
        sys.stdout.write("\033[2J\033[H" + out + "\r\n"); sys.stdout.flush()

    def print_page(self, lines, wait=True):
        out = "\r\n".join(vfit(str(l), TERM_WIDTH) for l in lines)
        if wait: out += "\r\n\r\n  [Press Enter to continue]\r\n"
        sys.stdout.write("\033[2J\033[H" + out); sys.stdout.flush()
        if wait:
            while True:
                k = self.get_key_no_flush(0.5)
                if k in ('\r', '\n'): break
            sys.stdout.write("\033[2J"); sys.stdout.flush()

    def flash_white(self):
        """Brief white-screen flash."""
        try: cols, rows = os.get_terminal_size()
        except: cols, rows = TERM_WIDTH, 24
        sys.stdout.write("\033[2J\033[H\033[47m\033[30m")
        for _ in range(rows):
            sys.stdout.write((" " * cols) + "\n")
        sys.stdout.write("\033[0m"); sys.stdout.flush()
        time.sleep(0.05)
        sys.stdout.write("\033[2J\033[0m"); sys.stdout.flush()

    def flash_red(self):
        """Brief red-screen flash for damage events (lightning, tornado)."""
        try: cols, rows = os.get_terminal_size()
        except: cols, rows = TERM_WIDTH, 24
        sys.stdout.write("\033[2J\033[H\033[41m\033[97m")
        for _ in range(rows):
            sys.stdout.write((" " * cols) + "\n")
        sys.stdout.write("\033[0m"); sys.stdout.flush()
        time.sleep(0.05)
        sys.stdout.write("\033[2J\033[0m"); sys.stdout.flush()

    def render_main(self, header, scan, msg, prompt, buf, player=None, paused=False):
        sys.stdout.write("\033[H")
        try: cols, term_h = os.get_terminal_size()
        except: cols, term_h = TERM_WIDTH, 24
        term_w = min(cols, TERM_WIDTH)
        if term_h < 10: term_h = 10
        max_scan = term_h - 12
        scan = scan[:max_scan]
        out = list(header)
        out.append("─" * term_w)
        out.extend(scan)
        out.append("─" * term_w)
        out.extend(msg[-3:])
        out.append("")
        if player and player.active_tasks:
            t = player.active_tasks[0]
            rem = max(0, int(t["end"] - time.time()))
            out.append(f"🔨 Crafting: {t['item'].replace('_',' ').title()} ({rem}s) — movement locked")
        if paused:
            out.append("⏸️ GAME PAUSED — time, weather, and auto-walk are frozen until you resume.")
        elif player and player.resting:
            mode = "🔥 Campfire" if player.rest_mode == "campfire" else "😴 Floor"
            fuel = f" | 🪵{player.campfire_fuel} fuel left" if player.rest_mode == "campfire" else ""
            out.append(f"{mode} REST active: +30😴/hr{fuel} — type 'rest' to stop")
        elif player and player.traps:
            setting = sum(1 for t in player.traps if t.get('status') == 'setting')
            caught  = sum(1 for t in player.traps if t.get('status') == 'caught')
            parts = []
            if setting: parts.append(f"⏳{setting} setting")
            if caught:  parts.append(f"🟢{caught} CAUGHT!")
            out.append("🪤 Traps: " + " | ".join(parts))
        else:
            out.append(" " * term_w)
        if buf:
            out.append(buf)
        else:
            out.append(" " * term_w)
        out.append(f"{prompt}{buf}")
        while len(out) < term_h: out.append(" " * term_w)
        out = out[:term_h]
        final = "\r\n".join([vfit(str(l), term_w) for l in out])
        sys.stdout.write(final + "\033[J")
        cursor_pos = vlen(prompt) + vlen(buf) + 1
        if cursor_pos > term_w: cursor_pos = term_w
        sys.stdout.write(f"\033[{term_h};{cursor_pos}H\033[?25h"); sys.stdout.flush()

