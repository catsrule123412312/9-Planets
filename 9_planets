def _temp_label(temp):
    """Return a short temperature label for the HUD."""
    if temp < 10:    return "🥶❄️ Freezing"
    if temp <= 30:   return f"❄️ Cold ({temp:.0f})"
    if temp <= 65:   return f"😊 Comfy"
    if temp <= 80:   return f"🌡️ Warm ({temp:.0f})"
    if temp <= 90:   return f"🔆 Hot ({temp:.0f})"
    return               f"🔥 Burning!"

def _fmt_playtime(secs):
    h = int(secs // 3600); m = int((secs % 3600) // 60)
    return f"{h}h {m}m" if h else f"{m}m"

