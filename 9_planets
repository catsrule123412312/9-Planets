                self.enabled = True
                self._load_sounds()
                break
            except Exception:
                continue

    def _make_sound(self, samples):
        if not self.enabled:
            return None
        try:
            return pygame.mixer.Sound(buffer=array('h', samples))
        except Exception:
            return None

    def _envelope(self, t, duration):
        if t < 0.05:
            return t / 0.05
        if t > duration - 0.05:
            return max(0.0, (duration - t) / 0.05)
        return 1.0

    def _tone(self, freq, duration, volume=0.20, shape="sine", detune=0.0):
        samples = []
        for i in range(int(SOUND_SAMPLE_RATE * duration)):
            t = i / SOUND_SAMPLE_RATE
            if shape == "triangle":
                cycle = (t * freq) % 1.0
                value = 2.0 * abs(2.0 * cycle - 1.0) - 1.0
            elif shape == "square":
                value = 1.0 if math.sin(2.0 * math.pi * freq * t) >= 0 else -1.0
            else:
                value = math.sin(2.0 * math.pi * freq * t)
            if detune:
                value += 0.3 * math.sin(2.0 * math.pi * (freq + detune) * t)
            env = self._envelope(t, duration)
            samples.append(int(max(-1.0, min(1.0, value * volume * env)) * 32767))
        return self._make_sound(samples)

    def _noise(self, duration, volume=0.16, tone_freq=0.0):
        samples = []
        noise_val = 0.0
        for i in range(int(SOUND_SAMPLE_RATE * duration)):
            t = i / SOUND_SAMPLE_RATE
            noise_val = noise_val * 0.96 + (random.random() * 2.0 - 1.0) * 0.08
            value = noise_val
            if tone_freq:
                value += 0.2 * math.sin(2.0 * math.pi * tone_freq * t)
            env = self._envelope(t, duration)
            samples.append(int(max(-1.0, min(1.0, value * volume * env)) * 32767))
        return self._make_sound(samples)

    def _sequence(self, notes, durations, volume=0.18):
        samples = []
        for freq, dur in zip(notes, durations):
            for i in range(int(SOUND_SAMPLE_RATE * dur)):
                t = i / SOUND_SAMPLE_RATE
                value = math.sin(2.0 * math.pi * freq * t)
                env = self._envelope(t, dur)
                samples.append(int(max(-1.0, min(1.0, value * volume * env)) * 32767))
        return self._make_sound(samples)

    def _load_sounds(self):
        self.sounds["intro"] = self._sequence([330, 392, 440, 392, 330, 262], [0.18, 0.14, 0.16, 0.12, 0.16, 0.20], volume=0.16)
        self.sounds["forest"] = self._tone(180, 1.20, volume=0.06, shape="triangle")
        self.sounds["arctic"] = self._tone(120, 1.40, volume=0.05, shape="triangle")
        self.sounds["walk"] = self._tone(260, 0.05, volume=0.12)
        self.sounds["collect"] = self._tone(720, 0.08, volume=0.16, detune=15)
        self.sounds["attack"] = self._sequence([440, 220], [0.08, 0.10], volume=0.22)
        self.sounds["animal"] = self._sequence([660, 520], [0.10, 0.14], volume=0.12)
        self.sounds["lightning"] = self._noise(0.18, volume=0.22, tone_freq=80)
        self.sounds["tornado"] = self._noise(0.70, volume=0.10, tone_freq=120)
        self.sounds["low_health"] = self._tone(440, 0.12, volume=0.20, shape="square")
        self.sounds["death"] = self._sequence([110, 82, 65], [0.20, 0.25, 0.28], volume=0.18, shape="triangle")

    def _play(self, sound_name, loops=0, channel=None):
        if not self.enabled:
            return
        sound = self.sounds.get(sound_name)
        if not sound:
            return
        try:
            if channel is None:
                channel = pygame.mixer.find_channel(True)
            channel.play(sound, loops=loops)
        except Exception:
            pass

    def play_intro(self):
        if not self.enabled: return
        self._play("intro", loops=-1, channel=self.bgm_channel)

    def play_environment(self, biome):
        if not self.enabled or self.last_biome == biome:
            return
        self.last_biome = biome
        sound_name = "forest" if biome == "Forest" else "arctic"
        if self.ambient_channel:
            self.ambient_channel.play(self.sounds.get(sound_name), loops=-1)

    def play_walk(self):
        self._play("walk")

    def play_collect(self):
        self._play("collect")

    def play_attack(self):
        self._play("attack")

    def play_animal(self):
        self._play("animal")

    def play_lightning(self):
        self._play("lightning")

    def play_tornado(self):
        self._play("tornado")

    def play_low_health(self):
        self._play("low_health")

    def play_death(self):
        self._play("death")
